#!/usr/bin/env python3
"""
cinder — Sandboxed terminal browser for Termux (ARMv7+).
Isolated browsing sessions with image support via links2 + chafa.
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
import tempfile
import time
import urllib.request
import uuid
from datetime import datetime
from pathlib import Path
from urllib.parse import urlparse

CINDER_DIR = Path.home() / ".cinder"
SESSIONS_DIR = CINDER_DIR / "sessions"
CONFIG_PATH = CINDER_DIR / "config.json"
VERSION = "1.1.0"

DEFAULT_CONFIG = {
    "default_browser": "auto",
    "image_viewer": "auto",
    "max_sessions": 30,
    "cleanup_days": 14,
    "save_history": True,
    "use_tmux": False,
}


def Y(s):
    return f"\033[33m{s}\033[0m"


def C(s):
    return f"\033[36m{s}\033[0m"


def G(s):
    return f"\033[32m{s}\033[0m"


def R(s):
    return f"\033[31m{s}\033[0m"


def D(s):
    return f"\033[2m{s}\033[0m"


def load_config():
    cfg = DEFAULT_CONFIG.copy()
    if CONFIG_PATH.exists():
        try:
            cfg.update(json.loads(CONFIG_PATH.read_text()))
        except Exception:
            pass
    return cfg


def save_config(cfg):
    CINDER_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps(cfg, indent=2))


def ensure_dirs():
    CINDER_DIR.mkdir(parents=True, exist_ok=True)
    SESSIONS_DIR.mkdir(parents=True, exist_ok=True)
    if not CONFIG_PATH.exists():
        save_config(DEFAULT_CONFIG)


def _read_or_empty(p):
    try:
        return p.read_text()
    except (OSError, FileNotFoundError):
        return ""


def _write_safe(p, text):
    tmp = p.with_suffix(".tmp")
    tmp.write_text(text)
    tmp.rename(p)


class Session:
    def __init__(self, sid):
        self.id = sid
        self.path = SESSIONS_DIR / sid
        self.meta_path = self.path / "meta.json"
        self.cookie_path = self.path / "cookies.txt"
        self.history_path = self.path / "history.txt"
        self.bookmark_path = self.path / "bookmarks.txt"
        self.download_dir = self.path / "downloads"

    def exists(self):
        return self.path.is_dir()

    def create(self, url="", name=""):
        self.path.mkdir(parents=True, exist_ok=True)
        self.download_dir.mkdir(exist_ok=True)
        (self.path / ".links").mkdir(exist_ok=True)
        for p in (self.cookie_path, self.history_path, self.bookmark_path):
            p.touch()
        (self.path / ".links" / "links.cfg").touch()
        self._write_meta({
            "id": self.id,
            "name": name or self.id[:8],
            "created": time.time(),
            "updated": time.time(),
            "url": url or "",
            "browser": "links2",
        })

    def _write_meta(self, m):
        self.meta_path.write_text(json.dumps(m, indent=2))

    def meta(self):
        if not self.meta_path.exists():
            return {}
        try:
            return json.loads(self.meta_path.read_text())
        except (json.JSONDecodeError, OSError):
            return {}

    def update(self, **kw):
        m = self.meta()
        m.update(kw)
        m["updated"] = time.time()
        self._write_meta(m)

    def add_history(self, url, title=""):
        if not url:
            return
        content = _read_or_empty(self.history_path)
        _write_safe(self.history_path, content + f"{int(time.time())}|{url}|{title}\n")

    def history(self, limit=50):
        raw = _read_or_empty(self.history_path).strip()
        if not raw:
            return []
        result = []
        for line in raw.split("\n")[-limit:]:
            parts = line.split("|", 2)
            if len(parts) >= 2:
                t = parts[0]
                url = parts[1]
                title = parts[2] if len(parts) > 2 else ""
                result.append({"time": int(t), "url": url, "title": title})
        return result

    def add_bookmark(self, url, title=""):
        if not url:
            return
        with open(self.bookmark_path, "a") as f:
            f.write(f"{url}|{title}\n")

    def bookmarks(self):
        raw = _read_or_empty(self.bookmark_path).strip()
        if not raw:
            return []
        result = []
        for line in raw.split("\n"):
            if "|" in line:
                u, t = line.split("|", 1)
                result.append({"url": u, "title": t})
        return result

    def delete(self):
        shutil.rmtree(self.path, ignore_errors=True)

    def size_kb(self):
        total = 0
        for f in self.path.rglob("*"):
            if f.is_file():
                total += f.stat().st_size
        return total // 1024


def detect_browsers():
    return [b for b in ("links2", "links", "w3m", "lynx", "elinks") if shutil.which(b)]


def detect_display_mode():
    if os.environ.get("DISPLAY"):
        return "x11"
    if os.environ.get("WAYLAND_DISPLAY"):
        return "wayland"
    if os.path.exists("/dev/fb0"):
        return "fb"
    term = os.environ.get("TERM", "")
    if "sixel" in term.lower():
        return "sixel"
    if "kitty" in term.lower():
        return "kitty"
    return "text"


def detect_image_viewer():
    for name in ("chafa", "catimg", "jp2a"):
        if shutil.which(name):
            return name
    if shutil.which("termux-open"):
        return "termux-open"
    if shutil.which("xdg-open"):
        return "xdg-open"
    return ""


def is_termux():
    return shutil.which("pkg") is not None


def view_image(path, viewer=""):
    if not os.path.isfile(path):
        print(f"{R('✗')} File not found: {path}")
        return False
    viewer = viewer or detect_image_viewer()
    if not viewer:
        print(f"{R('✗')} No image viewer. Install: {Y('chafa')}, {Y('catimg')}, or {Y('jp2a')}")
        return False
    try:
        cmds = {
            "chafa": ["chafa", "--symbols=block", "--colors=256", "--scale=max", path],
            "catimg": ["catimg", "-w", "120", path],
            "jp2a": ["jp2a", "--colors", "--width=120", path],
        }
        if viewer in cmds:
            subprocess.run(cmds[viewer], check=False)
        else:
            subprocess.run([viewer, path], check=False)
        return True
    except FileNotFoundError:
        print(f"{R('✗')} Viewer '{viewer}' not found")
        return False


def view_image_url(url, viewer=""):
    suffix = os.path.splitext(urlparse(url).path)[1] or ".img"
    tmp = tempfile.NamedTemporaryFile(suffix=suffix, delete=False)
    tmp_name = tmp.name
    tmp.close()
    try:
        print(f"  {C('⬇')} Downloading {D(url)}...")
        urllib.request.urlretrieve(url, tmp_name)
        return view_image(tmp_name, viewer)
    except Exception as e:
        print(f"  {R('✗')} Download failed: {e}")
        return False
    finally:
        try:
            os.unlink(tmp_name)
        except OSError:
            pass


def normalize_url(url):
    url = url.strip()
    if not url:
        return ""
    if not url.startswith(("http://", "https://", "ftp://", "file://")):
        url = "https://" + url
    return url


def captcha_view(sid, viewer=""):
    session = Session(sid)
    if not session.exists():
        print(f"{R('✗')} Session '{sid}' not found")
        return
    images = sorted(session.download_dir.glob("*.*"), key=os.path.getmtime, reverse=True)
    images = [f for f in images if f.suffix.lower() in (".png", ".jpg", ".jpeg", ".gif", ".bmp", ".webp")]
    if not images:
        print(f"  {Y('!')} No images in session downloads")
        return
    print(f"  {C('📸')} Images in session {D(sid[:8])}:")
    print(f"  {'#':<4} {'Name':<36} {'Size':<10} {'Modified':<16}")
    print(f"  {D('—'*66)}")
    for i, img in enumerate(images[:10], 1):
        kb = img.stat().st_size // 1024
        size = f"{kb}KB" if kb else f"{img.stat().st_size}B"
        mtime = datetime.fromtimestamp(img.stat().st_mtime).strftime("%m-%d %H:%M")
        print(f"  {i:<4} {img.name:<36} {size:<10} {mtime:<16}")
    try:
        choice = input(f"\n  {C('›')} Select image (1-{min(len(images), 10)}): ")
        idx = int(choice) - 1
        if 0 <= idx < len(images):
            view_image(str(images[idx]), viewer)
        else:
            print(f"  {R('✗')} Invalid choice")
    except (ValueError, IndexError):
        print(f"  {R('✗')} Invalid choice")


def launch_browser(url, sid, browser="auto", use_tmux=False):
    s = Session(sid)
    if not s.exists():
        print(f"{R('✗')} Session '{sid}' not found")
        return False

    available = detect_browsers()
    if not available:
        print(f"{R('✗')} No browser found. Run: {Y('cinder install-deps')}")
        return False

    if browser == "auto":
        browser = next((b for b in ("links2", "links", "w3m") if b in available), available[0])

    env = os.environ.copy()
    env["HOME"] = str(s.path)
    mode = detect_display_mode()

    cmd = [browser]

    if browser in ("links2", "links"):
        cfg_dir = s.path / ".links"
        cfg_dir.mkdir(exist_ok=True)
        cfg_file = cfg_dir / "links.cfg"
        cfg_file.write_text(
            "set javascript = 1\n"
            f"set download_directory = {s.download_dir}\n"
        )
        if mode in ("x11", "wayland", "fb"):
            cmd.append("-g")
            print(f"  {C('🖥')} Display: {G(mode)} (graphical)")
        else:
            print(f"  {C('🖥')} Display: {Y('text')} (256 colors)")
    elif browser == "w3m":
        cmd.extend(["-cookie", "-cookie_file", str(s.cookie_path)])
        env["W3M_HOME"] = str(s.path)

    url = normalize_url(url)
    if url:
        s.add_history(url)
        cmd.append(url)

    s.update(url=url or "", last_active=int(time.time()))

    try:
        if use_tmux and shutil.which("tmux"):
            ses_name = f"cinder-{sid[:8]}"
            has = subprocess.run(["tmux", "has-session", "-t", ses_name], capture_output=True)
            if has.returncode == 0:
                print(f"  {C('↻')} Re-attaching to tmux session {D(ses_name)}")
                subprocess.run(["tmux", "attach", "-t", ses_name], check=False)
            else:
                print(f"  {C('▣')} Starting tmux session {D(ses_name)}")
                subprocess.run(["tmux", "new-session", "-d", "-s", ses_name] + cmd, env=env, check=False)
                subprocess.run(["tmux", "attach", "-t", ses_name], check=False)
        else:
            print(f"  {G('✓')} Browsing session {D(sid[:8])} — press Ctrl+C to exit")
            subprocess.run(cmd, env=env, check=False)
        s.update(last_active=int(time.time()))
        return True
    except FileNotFoundError:
        print(f"{R('✗')} Browser '{browser}' not found. Run: {Y('cinder install-deps')}")
        return False
    except KeyboardInterrupt:
        print(f"\n  {C('👋')} Session saved")
        s.update(last_active=int(time.time()))
        return True
    except Exception as e:
        print(f"{R('✗')} Error: {e}")
        return False


def resolve_session(partial):
    if not SESSIONS_DIR.is_dir():
        return None
    for name in os.listdir(str(SESSIONS_DIR)):
        if name == partial or name.startswith(partial):
            return name
    return None


def cmd_new(args):
    sid = uuid.uuid4().hex[:16]
    url = normalize_url(args.url or "")
    session = Session(sid)
    session.create(url, args.name or "")
    print(f"  {G('✦')} Session {C(sid[:8])} ({args.name or sid[:8]})")
    launch_browser(url, sid, args.browser, args.tmux)


def cmd_list(args):
    if not SESSIONS_DIR.is_dir():
        print(f"  {Y('!')} No sessions. Run: {C('cinder new <url>')}")
        return
    sessions = sorted(SESSIONS_DIR.iterdir(), key=lambda p: p.stat().st_mtime, reverse=True)
    if not sessions:
        print(f"  {Y('!')} No sessions")
        return
    print(f"  {C('ID'):<10} {C('Name'):<18} {C('URL'):<33} {C('Created'):<14}")
    print(f"  {D('—'*75)}")
    for p in sessions:
        s = Session(p.name)
        if not s.exists():
            continue
        m = s.meta()
        created = datetime.fromtimestamp(m.get("created", 0)).strftime("%m-%d %H:%M")
        url = m.get("url", "")[:31]
        name = m.get("name", p.name[:8])[:16]
        print(f"  {p.name[:8]:<10} {name:<18} {url:<33} {created:<14}")


def cmd_attach(args):
    sid = resolve_session(args.session_id)
    if not sid:
        print(f"{R('✗')} Session '{args.session_id}' not found")
        return
    m = Session(sid).meta()
    url = normalize_url(args.url or m.get("url", ""))
    print(f"  {C('↻')} Attaching to {C(sid[:8])}")
    launch_browser(url, sid, args.browser, args.tmux)


def cmd_rm(args):
    sid = resolve_session(args.session_id)
    if not sid:
        print(f"{R('✗')} Session '{args.session_id}' not found")
        return
    confirm = input(f"  {Y('⚠')} Delete session {C(sid[:8])} and all data? {D('(y/N)')}: ")
    if confirm.lower() in ("y", "yes"):
        Session(sid).delete()
        print(f"  {G('✓')} Deleted {C(sid[:8])}")
    else:
        print(f"  {Y('!')} Cancelled")


def cmd_img(args):
    if args.url_or_path.startswith(("http://", "https://")):
        view_image_url(args.url_or_path, args.viewer)
    else:
        view_image(args.url_or_path, args.viewer)


def cmd_captcha(args):
    sid = resolve_session(args.session_id)
    if not sid:
        print(f"{R('✗')} Session '{args.session_id}' not found")
        return
    captcha_view(sid, args.viewer)


def cmd_history(args):
    sid = resolve_session(args.session_id)
    if not sid:
        print(f"{R('✗')} Session '{args.session_id}' not found")
        return
    entries = Session(sid).history(args.limit)
    if not entries:
        print(f"  {Y('!')} No history")
        return
    for e in reversed(entries):
        dt = datetime.fromtimestamp(e["time"]).strftime("%H:%M")
        title = f" {D('—')} {e['title']}" if e["title"] else ""
        print(f"  [{D(dt)}] {e['url']}{title}")


def cmd_bookmarks(args):
    sid = resolve_session(args.session_id)
    if not sid:
        print(f"{R('✗')} Session '{args.session_id}' not found")
        return
    bms = Session(sid).bookmarks()
    if not bms:
        print(f"  {Y('!')} No bookmarks")
        return
    for i, b in enumerate(bms, 1):
        title = f" {D('—')} {b['title']}" if b["title"] else ""
        print(f"  {i}. {b['url']}{title}")


def cmd_info(args):
    sid = resolve_session(args.session_id)
    if not sid:
        print(f"{R('✗')} Session '{args.session_id}' not found")
        return
    s = Session(sid)
    m = s.meta()
    if not m:
        print(f"{R('✗')} Session data corrupted for '{sid[:8]}'")
        return
    print(f"  {C('ID')}:      {sid}")
    print(f"  {C('Name')}:    {m.get('name', '—')}")
    print(f"  {C('Created')}: {datetime.fromtimestamp(m.get('created', 0)).strftime('%Y-%m-%d %H:%M')}")
    print(f"  {C('Updated')}: {datetime.fromtimestamp(m.get('updated', 0)).strftime('%Y-%m-%d %H:%M')}")
    print(f"  {C('URL')}:     {m.get('url', '—')}")
    print(f"  {C('Size')}:    {s.size_kb()}KB")
    cookie_size = s.cookie_path.stat().st_size if s.cookie_path.exists() else 0
    print(f"  {C('Cookies')}: {cookie_size}B")
    print(f"  {C('History')}: {len(s.history())} entries")
    print(f"  {C('Bookmarks')}: {len(s.bookmarks())}")
    imgs = sum(1 for f in s.download_dir.glob("*.*") if f.suffix.lower() in (".png", ".jpg", ".jpeg", ".gif", ".bmp", ".webp"))
    print(f"  {C('Images')}:  {imgs}")


def cmd_rename(args):
    sid = resolve_session(args.session_id)
    if not sid:
        print(f"{R('✗')} Session '{args.session_id}' not found")
        return
    s = Session(sid)
    s.update(name=args.name)
    print(f"  {G('✓')} Renamed to {C(args.name)}")


def cmd_export(args):
    sid = resolve_session(args.session_id)
    if not sid:
        print(f"{R('✗')} Session '{args.session_id}' not found")
        return
    s = Session(sid)
    out = Path(args.output) if args.output else Path.cwd() / f"cinder-{sid[:8]}"
    if out.exists():
        confirm = input(f"  {Y('⚠')} Directory {C(str(out))} exists. Overwrite? {D('(y/N)')}: ")
        if confirm.lower() not in ("y", "yes"):
            print(f"  {Y('!')} Cancelled")
            return
    out.mkdir(parents=True, exist_ok=True)
    for item in s.path.iterdir():
        if item.is_file():
            shutil.copy2(item, out / item.name)
    print(f"  {G('✓')} Exported to {C(str(out))}")


def cmd_clean(args):
    if not SESSIONS_DIR.is_dir():
        return
    cutoff = time.time() - (args.days * 86400)
    count = 0
    for p in SESSIONS_DIR.iterdir():
        if p.is_dir() and p.stat().st_mtime < cutoff:
            shutil.rmtree(p, ignore_errors=True)
            count += 1
    print(f"  {G('✓')} Cleaned {count} old session(s)")


def cmd_config(args):
    cfg = load_config()
    if args.edit:
        editor = os.environ.get("EDITOR", "vi")
        subprocess.run([editor, str(CONFIG_PATH)], check=False)
        return
    print(json.dumps(cfg, indent=2))


def cmd_install_deps(args):
    if is_termux():
        pm = "pkg"
        deps = ["python3", "links", "w3m", "chafa", "catimg"]
    elif shutil.which("apt-get"):
        pm = "apt-get"
        deps = ["python3", "links2", "w3m", "chafa", "catimg"]
    elif shutil.which("apt"):
        pm = "apt"
        deps = ["python3", "links2", "w3m", "chafa", "catimg"]
    else:
        print(f"{R('✗')} Unsupported package manager. Install manually:")
        print(f"  links2, w3m, chafa, catimg")
        return
    print(f"  {C('📦')} Installing via {Y(pm)}: {' '.join(deps)}")
    try:
        subprocess.run([pm, "update", "-y"], check=False)
        subprocess.run([pm, "install", "-y"] + deps, check=False)
        print(f"  {G('✓')} Done!")
    except Exception as e:
        print(f"{R('✗')} Failed: {e}")


def main():
    ensure_dirs()

    parser = argparse.ArgumentParser(
        prog="cinder",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description="Sandboxed terminal browser for Termux — isolated sessions with image support",
        epilog=f"""
{D('Examples')}:
  {C('cinder new https://example.com')}     {D('new session + browse')}
  {C('cinder new --tmux example.com')}      {D('browse in tmux session')}
  {C('cinder list')}                        {D('list sessions')}
  {C('cinder attach abc123')}               {D('re-open session')}
  {C('cinder captcha abc123')}              {D('view CAPTCHA images')}
  {C('cinder img https://site.com/a.png')}  {D('view image in terminal')}
  {C('cinder install-deps')}                {D('install deps')}
        """,
    )
    parser.add_argument("--version", action="version", version=f"cinder {VERSION}")

    sub = parser.add_subparsers(dest="command")

    def common(p):
        p.add_argument("--browser", "-b", default="auto", help="Browser engine (links2, w3m, lynx)")
        p.add_argument("--viewer", "-v", default="", help="Image viewer (chafa, catimg, termux-open)")
        p.add_argument("--tmux", action="store_true", help="Use tmux session")

    p = sub.add_parser("new", help="Create a new session and start browsing")
    p.add_argument("url", nargs="?", default="", help="URL to open")
    p.add_argument("--name", "-n", default="", help="Friendly session name")
    common(p)
    p.set_defaults(func=cmd_new)

    p = sub.add_parser("list", aliases=["ls"], help="List all sessions")
    p.set_defaults(func=cmd_list)

    p = sub.add_parser("attach", help="Re-attach to an existing session")
    p.add_argument("session_id", help="Session ID (prefix accepted)")
    p.add_argument("url", nargs="?", default="", help="New URL to open")
    common(p)
    p.set_defaults(func=cmd_attach)

    p = sub.add_parser("rm", aliases=["delete", "remove"], help="Delete a session and all its data")
    p.add_argument("session_id")
    p.set_defaults(func=cmd_rm)

    p = sub.add_parser("img", help="View an image in the terminal")
    p.add_argument("url_or_path", help="Image URL or local file path")
    p.add_argument("--viewer", "-v", default="")
    p.set_defaults(func=cmd_img)

    p = sub.add_parser("captcha", aliases=["cap"], help="View downloaded images (CAPTCHAs) from a session")
    p.add_argument("session_id")
    p.add_argument("--viewer", "-v", default="")
    p.set_defaults(func=cmd_captcha)

    p = sub.add_parser("history", aliases=["hist"], help="Show browsing history for a session")
    p.add_argument("session_id")
    p.add_argument("--limit", "-l", type=int, default=50, help="Max entries")
    p.set_defaults(func=cmd_history)

    p = sub.add_parser("bookmarks", aliases=["bm"], help="Show bookmarks for a session")
    p.add_argument("session_id")
    p.set_defaults(func=cmd_bookmarks)

    p = sub.add_parser("info", help="Show detailed session information")
    p.add_argument("session_id")
    p.set_defaults(func=cmd_info)

    p = sub.add_parser("rename", help="Rename a session")
    p.add_argument("session_id")
    p.add_argument("name", help="New name")
    p.set_defaults(func=cmd_rename)

    p = sub.add_parser("export", help="Export session data to a directory")
    p.add_argument("session_id")
    p.add_argument("--output", "-o", default="", help="Output directory")
    p.set_defaults(func=cmd_export)

    p = sub.add_parser("clean", help="Remove sessions older than N days")
    p.add_argument("--days", "-d", type=int, default=14, help="Max age in days")
    p.set_defaults(func=cmd_clean)

    p = sub.add_parser("config", help="View or edit configuration")
    p.add_argument("--edit", "-e", action="store_true", help="Edit with $EDITOR")
    p.set_defaults(func=cmd_config)

    p = sub.add_parser("install-deps", help="Install browser and image dependencies")
    p.set_defaults(func=cmd_install_deps)

    args = parser.parse_args()
    if args.command is None:
        parser.print_help()
        return
